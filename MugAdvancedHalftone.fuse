    })
    self:EndControlNest();

    self:BeginControlNest("Dot Color", "DotColorNest", true);
    InRGBShift = self:AddInput("RGB Shift (Req. Color/Blend)", "RGBShift", {
        LINKID_DataType = "Number",
        INPID_InputControl = "SliderControl",
