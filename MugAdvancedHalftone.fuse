-- Set this to true to export CellInfo1-2 as additional outputs for debugging
ShowCellInfo = false

-- Set version globally for easy maintenance
VERSION = 2.35

--******************************************************************************************************
FuRegisterClass("MugAdvancedHalftone", CT_Tool, {
    REGS_Category          = "Fuses\\Mug",
    REGS_OpIconString      = "MAH",
    REGS_OpDescription     = "Mug Advanced Halftone",
    REGS_HelpTopic         = "https://x.com/MugLab3",
    REGS_URL               = "https://www.youtube.com/@MugLab3",
    REGS_IconID            = "Icons.Tools.Icons.AdvancedHalftone",
    REG_Source_GlobalCtrls = true,
    REG_Source_SizeCtrls   = true,
    REG_Version            = math.floor(VERSION * 100),
})

-- Palette Mapping Types
PALETTE_TYPE = {
    NONE = 0,
    LUMA = 1,             -- Luminance-based mapping (4-16 colors)
    RGB = 2,              -- 3-bit RGB color cuboid (8 colors)
    NEAREST_NEIGHBOR = 3, -- Perceptual nearest neighbor matching (16-32 colors)
}

